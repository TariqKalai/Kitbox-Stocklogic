<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Stocklogic.ViewModels"
             x:Class="Stocklogic.Views.LockerPage"
             x:DataType="vm:LockerPageViewModel">
  <DockPanel LastChildFill="True">
      <Border Height="60"
              Background="White"
              BorderBrush="#E0E0E0"
              BorderThickness="0,1,0,0"
              DockPanel.Dock="Bottom">
        <StackPanel Margin="0,0,20,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
          <Button Content="Back"
                  Command="{Binding BackCommand}"
                  IsEnabled="True"
                  Margin="0,0,20,0"
                  Background="Transparent"
                  FontWeight="Bold"
                  Foreground="Black" />
          <Button Content="Continue"
                  Command="{Binding ContinueCommand}"
                  Background="Black"
                  CornerRadius="5"
                  Foreground="White"
                  Padding="30,10" />
        </StackPanel>
      </Border>
    <Grid Margin="40" ColumnDefinitions="*, *" RowDefinitions="*, *">
      
      <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" 
              Margin="10" Background="#D9EDC3" CornerRadius="20" BorderThickness="2" BorderBrush="#B9CBA5">
        <StackPanel Margin="20" Spacing="20">
          <TextBlock Text="Add a locker" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
          
          <StackPanel Spacing="10">
            <TextBlock Text="Height :"/>
            <ComboBox ItemsSource="{Binding AvailableHeights}" SelectedItem="{Binding NewLockerHeight}" HorizontalAlignment="Stretch"/>
            <Button Content="Add to cabinet" Command="{Binding AddLockerCommand}" 
                    HorizontalAlignment="Center" Margin="0,10" Background="Black" Foreground="White"/>
          </StackPanel>

          <Separator Height="2" Background="#B9CBA5"/>

          <TextBlock Text="Preview" FontWeight="Bold"/>
          <ItemsControl ItemsSource="{Binding Lockers}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Height="{Binding Height}" Margin="5" Background="White" BorderBrush="Black" BorderThickness="1">
                  <TextBlock Text="Casier" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Grid.Row="0" Grid.Column="1" Margin="10" Background="White" CornerRadius="20" BorderThickness="1" BorderBrush="#E0E0E0">
        <Grid Margin="15">
          <StackPanel Spacing="10">
            <TextBlock Text="Locker properties" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedLocker.Description, FallbackValue='No locker selected'}"/>
            <TextBlock Text="{Binding SelectedLocker.Dimensions}"/>
          </StackPanel>
          
          <Button Content="X" Command="{Binding RemoveLockerCommand}" 
                  HorizontalAlignment="Right" VerticalAlignment="Top" 
                  Background="Red" Foreground="White" CornerRadius="15"/>
        </Grid>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Margin="10" Background="#DCEDC8" CornerRadius="20">
        <StackPanel Margin="20" VerticalAlignment="Center">
          <TextBlock Text="Review" FontSize="20" FontWeight="Bold"/>
          <Separator Margin="0,10"/>
          <TextBlock Text="{Binding TotalItemsCount, StringFormat='Number of lockers : {0}'}"/>
          <TextBlock Text="{Binding TotalPrice, StringFormat='Total Price : {0} €'}" 
                    FontSize="24" FontWeight="Black" Margin="0,10,0,0"/>
        </StackPanel>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>