<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Stocklogic.ViewModels"
             x:Class="Stocklogic.Views.LockerPage"
             x:DataType="vm:LockerPageViewModel"
             Background="#F1F8E9">
  <DockPanel LastChildFill="True">
    <Border Height="60"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
      <StackPanel Margin="0,0,20,0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Orientation="Horizontal">
        <Button Content="Back"
                Command="{Binding BackCommand}"
                IsEnabled="True"
                Margin="0,0,20,0"
                Background="Transparent"
                FontWeight="Bold"
                Foreground="Black" />
        <Button Content="Continue"
                Command="{Binding ContinueCommand}"
                Background="Black"
                CornerRadius="5"
                Foreground="White"
                Padding="30,10" 
                />
      </StackPanel>
    </Border>

    <Grid Margin="40" ColumnDefinitions="*, *" RowDefinitions="*, *">

      <!-- Colonne gauche : Add a locker + Preview -->
      <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
              Margin="10" Background="#D9EDC3" CornerRadius="20" BorderThickness="2" BorderBrush="#B9CBA5">
        <StackPanel Margin="20" Spacing="20">
          <TextBlock Text="Add a locker" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

          <StackPanel Spacing="10">
            <TextBlock Text="Height :"/>
            <ComboBox ItemsSource="{Binding AvailableHeights}" SelectedItem="{Binding NewLockerHeight}" HorizontalAlignment="Stretch"/>
            <Button Content="Add to cabine" Command="{Binding AddLockerCommand}"
                    HorizontalAlignment="Center" Margin="0,10" Background="Black" Foreground="White"/>
          </StackPanel>

          <Separator Height="2" Background="#B9CBA5"/>

          <TextBlock Text="Preview" FontWeight="Bold"/>
          <ItemsControl ItemsSource="{Binding Lockers}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Command="{Binding $parent[UserControl].((vm:LockerPageViewModel)DataContext).SelectLockerCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        Padding="0"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch">
                  <Border Height="{Binding Height}" Margin="5" Background="White"
                          BorderBrush="Black" BorderThickness="1">
                    <TextBlock Text="Locker" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Colonne droite haut : Modification -->
      <Border Grid.Row="0" Grid.Column="1" Margin="10" Background="#D9EDC3"
              CornerRadius="20" BorderThickness="2" BorderBrush="#A8C8E8"
              IsVisible="{Binding IsLockerSelected}">
        <Grid Margin="15">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
              <TextBlock Text="Modification/Creation" FontSize="22" FontWeight="Bold"/>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Price :" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedLocker.Price, StringFormat='{}{0} €'}" VerticalAlignment="Center"/>
              </StackPanel>

              <StackPanel Spacing="5">
                <TextBlock Text="Locker Color :" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding AvailableColors}"
                          SelectedItem="{Binding SelectedLocker.LockerColor}"
                          HorizontalAlignment="Stretch"/>
              </StackPanel>

              <StackPanel Spacing="5">
                <TextBlock Text="Doors Color :" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding AvailableColors}"
                          SelectedItem="{Binding SelectedLocker.DoorColor}"
                          HorizontalAlignment="Stretch"/>
              </StackPanel>

              <StackPanel Spacing="5">
                <TextBlock Text="Type Of Doors :" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding AvailableDoorTypes}"
                          SelectedItem="{Binding SelectedLocker.DoorType}"
                          HorizontalAlignment="Stretch"/>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <Button Content=" Delete" Command="{Binding RemoveLockerCommand}"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Background="#8B0000" Foreground="White" CornerRadius="10"
                  Padding="15,5" BorderThickness="0"/>
        </Grid>
      </Border>

      <!-- Colonne droite bas : Overview -->
      <Border Grid.Row="1" Grid.Column="1" Margin="10" Background="#DCEDC8" CornerRadius="20">
        <StackPanel Margin="20" VerticalAlignment="Center">
          <TextBlock Text="Overview" FontSize="20" FontWeight="Bold"/>
          <Separator Margin="0,10"/>
          <TextBlock Text="{Binding TotalItemsCount, StringFormat='Number of lockers : {0}'}"/>
          <TextBlock Text="{Binding TotalHeight, StringFormat='Current Height : {0} cm'}"/>
          <TextBlock Text="{Binding TotalWidth, StringFormat='Current Width : {0} cm'}"/>
          <TextBlock Text="{Binding TotalDepth, StringFormat='Current Depth : {0} cm'}"/>
          <TextBlock Text="{Binding TotalPrice, StringFormat='Total Price : {0} €'}"
                     FontSize="24" FontWeight="Black" Margin="0,10,0,0"/>
        </StackPanel>
      </Border>

    </Grid>
  </DockPanel>
</UserControl>